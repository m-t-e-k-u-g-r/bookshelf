### --- DB BOOKS ---

### GET ALL BOOKS
GET http://{{host}}:{{port}}/db/books HTTP/1.1

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
%}

### GET ALL BOOKS SORTED BY AUTHOR (DESCENDING)
GET http://{{host}}:{{port}}/db/books?sortBy=author&order=desc HTTP/1.1

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
%}

### GET ALL BOOKS AND HIDE ATTRIBUTES
GET http://{{host}}:{{port}}/db/books?hide=isbn,imgUrl HTTP/1.1

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
%}

### GET ONE BOOK (FIRST OF SEED)
GET http://{{host}}:{{port}}/db/books/9781806982516 HTTP/1.1

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
%}

### GET ONE BOOK - NOT FOUND
GET http://{{host}}:{{port}}/db/books/1234567890123 HTTP/1.1

> {%
    client.test("Request failed as expected", function() {
        client.assert(response.status === 404, "Response status is not 404");
    });
%}

### ADD NEW BOOK
POST http://{{host}}:{{port}}/db/books/9781853260001 HTTP/1.1

> {%
    client.test("Post book successful", function() {
        client.assert(response.status === 201, "Expected code 201, got: " + response.status);
    })
%}

### POST BOOK - INVALID ISBN (BAD REQUEST)
POST http://{{host}}:{{port}}/db/books/1234567890123 HTTP/1.1

> {%
    client.test("Post book invalid ISBN", function() {
        client.assert(response.status === 400, "Expected code 400, got: " + response.status);
    });
%}

### BATCH ADD BOOKS
POST http://{{host}}:{{port}}/db/books/batch HTTP/1.1
Content-Type: application/json

{
  "isbns": ["9780544003415", "9780141439518"]
}

> {%
    client.test("Batch add successful", function() {
        client.assert(response.status === 201, "Response status is not 201");
    });
%}

### REMOVE BOOK
DELETE http://{{host}}:{{port}}/db/books/9781853260001 HTTP/1.1

> {%
    client.test("Delete book successful", function() {
        client.assert(response.status === 204, "Expected code 204, got: " + response.status);
    })
%}


