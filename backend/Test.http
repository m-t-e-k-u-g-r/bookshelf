### ASSIGN BOOK TO SHELVES
POST http://{{host}}:{{port}}/db/shelves/ HTTP/1.1
Content-Type: application/json

{
  "isbn": "9781806982516",
  "shelves": ["ScienceFiction", "Favorites"]
}

> {%
    client.test("Add book to shelf", function() {
        client.assert(response.status === 201, "Response status is not 201");
    });
%}

### RENAME A SHELF
PUT http://{{host}}:{{port}}/db/shelves/ HTTP/1.1
Content-Type: application/json

{
  "oldShelfName": "ScienceFiction",
  "newShelfName": "Sci-Fi"
}

> {%
    client.test("Rename shelf", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
%}

